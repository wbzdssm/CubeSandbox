# CubeSandbox e2e_perf — 环境变量示例
# 复制为 tests/.env 后编辑。CLI 与环境变量优先于 .env。

# ===========================================================================
# 目标环境与鉴权
# ===========================================================================
CUBE_API_URL=http://127.0.0.1:3000
CUBE_API_KEY=
CUBE_TEMPLATE_ID=
CUBE_PROXY_NODE_IP=
CUBE_PROXY_PORT_HTTP=80
CUBE_SANDBOX_DOMAIN=cube.app

# ===========================================================================
# 外部压测脚本（逗号分隔 .py 路径）
# ===========================================================================
# examples/snapshot-rollback-clone/bench_*.py 已默认纳入，无需配置。
# 接入自定义脚本（约定 -c -n --rounds --no-header）时取消注释：
# CUBE_EXTERNAL_SCRIPTS=/path/to/bench_clone.py,/path/to/bench_create.py

# ===========================================================================
# 场景开关（设 1 开 / 留空关）
# ===========================================================================
# CUBE_RUN_IVSHMEM=1          # 启用 ivshmem（需节点 host + ivshmem 模板）
# CUBE_RUN_VOLUME=1           # 启用 Volume 场景
# CUBE_SKIP_DENSITY=1         # 设为 1 跳过部署密度测试
# CUBE_SKIP_SNAPSHOT_DIRTY=1  # 设为 1 跳过脏页 vs 快照耗时测试
# CUBE_IVSHMEM_TEMPLATE_ID=   # ivshmem 模板（留空回落 CUBE_TEMPLATE_ID）
CUBE_IVSHMEM_ITERATIONS=10000 # ivshmem mmap 读写迭代次数

# ===========================================================================
# 运行参数
# ===========================================================================
CUBE_PERF_ROUNDS=3      # 每场景压测轮数
CUBE_PERF_WARMUP=1      # 预热轮数（不计入统计）
CUBE_PERF_SETTLE=0      # 并发档位间静默秒数
CUBE_DENSITY_COUNT=100  # 密度测试最多同时起多少沙箱
CUBE_PERF_CLEANUP=1     # 轮间清理残留 micro-VM（0=不清理）

# -- 并发阶梯（全局默认） --
# 轻量场景（snapshot-create / rollback / pause-resume）
CUBE_PERF_CONCURRENCY=1,5,10

# 重量场景（template-create / snapshot-create-from / clone / 外部脚本）
CUBE_CREATE_CONCURRENCY=1,10,20,50

# -- 按场景覆盖并发（覆盖上面同名场景的全局值，不需要的不设） --
# template-create      → CUBE_TEMPLATE_CREATE_CONCURRENCY=1,10,20
# snapshot-create-from  → CUBE_SNAPSHOT_CREATE_FROM_CONCURRENCY=1,10,20
# clone                → CUBE_CLONE_CONCURRENCY=1,5,10
# snapshot-create       → CUBE_SNAPSHOT_CREATE_CONCURRENCY=1,3,5
# rollback              → CUBE_ROLLBACK_CONCURRENCY=1,3,5
# pause-resume          → CUBE_PAUSE_RESUME_CONCURRENCY=1,5,10

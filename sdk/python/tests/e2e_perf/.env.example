# CubeSandbox e2e_perf — 环境变量示例
# 复制为 tests/.env 后编辑。CLI 与环境变量优先于 .env。
#
# 首次运行时若没有 .env 会自动生成一份；跑完后本次实际用到的值二次写回，
# 下次直接 python3 -m e2e_perf 复用。

# ===========================================================================
# 目标环境与鉴权
# ===========================================================================
CUBE_API_URL=http://127.0.0.1:3000
CUBE_API_KEY=
CUBE_TEMPLATE_ID=
CUBE_PROXY_NODE_IP=
CUBE_PROXY_PORT_HTTP=80
CUBE_SANDBOX_DOMAIN=cube.app

# ===========================================================================
# 外部压测脚本
# ===========================================================================
# examples/snapshot-rollback-clone/bench_*.py 已默认纳入，无需配置此处。
# 如需接入自定义脚本（约定 -c -n --rounds --no-header）：
# CUBE_EXTERNAL_SCRIPTS=/path/to/bench_a.py,/path/to/bench_b.py

# ===========================================================================
# 场景开关
# ===========================================================================
# CUBE_RUN_IVSHMEM=1          # 启用 ivshmem（需节点 host + ivshmem 模板）
# CUBE_RUN_VOLUME=1           # 启用 Volume 场景
# CUBE_SKIP_DENSITY=1         # 跳过密度测试
# CUBE_SKIP_SNAPSHOT_DIRTY=1  # 跳过脏页测试
# CUBE_IVSHMEM_TEMPLATE_ID=   # ivshmem 专用模板（留空回落 CUBE_TEMPLATE_ID）
CUBE_IVSHMEM_ITERATIONS=10000 # ivshmem mmap 迭代次数

# ===========================================================================
# 运行参数
# ===========================================================================
CUBE_PERF_ROUNDS=3              # 每场景压测轮数
CUBE_PERF_CONCURRENCY=1,5,10    # 轻量场景并发阶梯（snapshot-create / rollback / pause-resume）
CUBE_CREATE_CONCURRENCY=1,10,20,50  # 重量场景并发阶梯（template-create / from-snapshot / clone / 外部脚本）
CUBE_PERF_WARMUP=1              # 预热轮数（剔除冷启动毛刺）
CUBE_PERF_SETTLE=0              # 并发档位间静默秒数
CUBE_DENSITY_COUNT=100          # 部署密度测试最大沙箱数
CUBE_PERF_CLEANUP=1             # 轮次间清理残留 micro-VM（0=关闭）

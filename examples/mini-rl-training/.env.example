# HuggingFace mirror (use hf-mirror.com to avoid timeout in China)
HF_ENDPOINT="https://hf-mirror.com"

# cube-sandbox platform connection
E2B_API_URL="http://<your-cube-sandbox-ip>:3000"
E2B_API_KEY="<your-api-key>"

# SWE-bench image template ID (obtained after injecting envd)
CUBE_TEMPLATE_ID="<your-template-id>"

# SSL certificate bundle for cube-sandbox (self-hosted with mkcert).
# Uses CUBE_SSL_CERT_FILE instead of SSL_CERT_FILE to avoid overriding
# Python's global CA bundle (which would break HTTPS to public sites).
CUBE_SSL_CERT_FILE="/etc/pki/tls/cert.pem"

# LLM API Keys (set the ones you need)
# For Gemini models (gemini/gemini-3-flash-preview, gemini/gemini-3-pro-preview)
GEMINI_API_KEY="<your-gemini-key>"

# For TokenHub models (glm-5, minimax-m2.7, kimi-k2.5,
#   deepseek-v3.2, deepseek-r1-0528, hunyuan-2.0-thinking-20251109)
TOKENHUB_API_KEY="<your-tokenhub-key>"

# For DeepSeek models (deepseek/deepseek-chat, deepseek/deepseek-reasoner)
DEEPSEEK_API_KEY="<your-deepseek-key>"

# For OpenAI-compatible models (set to TOKENHUB_API_KEY when using TokenHub)
OPENAI_API_KEY="<your-openai-key>"

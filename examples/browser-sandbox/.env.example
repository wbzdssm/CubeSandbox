# Required: Cube API server address
E2B_API_URL="http://<your-node-ip>:3000"

# Required: any non-empty value satisfies the SDK check
E2B_API_KEY="e2b_000000"

# Required: template ID obtained from Step 1 (create-from-image)
CUBE_TEMPLATE_ID="<your-template-id>"

# Optional: only needed when using Cube's built-in cube.app mkcert certificate
# NODE_EXTRA_CA_CERTS="/root/.local/share/mkcert/rootCA.pem"

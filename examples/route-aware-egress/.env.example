# Cube API server address.
export E2B_API_URL="http://<your-node-ip>:3000"

# Any non-empty value satisfies the SDK check for local Cube deployments.
export E2B_API_KEY="e2b_000000"

# Template ID created by cubemastercli tpl create-from-image.
export CUBE_TEMPLATE_ID="<your-template-id>"

# Optional: only needed when using Cube's built-in mkcert certificate.
export SSL_CERT_FILE="/root/.local/share/mkcert/rootCA.pem"

# Dual-NIC example.
# PUBLIC_TARGET_IP should follow the host default route, normally through the
# primary NIC. SECONDARY_NIC_TARGET_IP should have a host route through the
# secondary NIC.
export PUBLIC_TARGET_IP="1.1.1.1"
export PUBLIC_TARGET_TCP_PORT="53"
export SECONDARY_NIC_TARGET_IP="<internal-target-ip>"
# Optional. Set this when the internal target has a TCP service to connect to.
export SECONDARY_NIC_TARGET_TCP_PORT=""
export PRIMARY_NIC_NAME="eth0"
export SECONDARY_NIC_NAME="eth1"

# GRE gateway example.
# GRE_REMOTE_TUNNEL_IP is the peer address inside the GRE tunnel.
# GRE_INTERNET_TARGET_IP should be reachable through the GRE remote gateway
# after host policy routing / routes are configured.
export GRE_TUNNEL_NAME="natgre"
export GRE_REMOTE_TUNNEL_IP="<gre-peer-tunnel-ip>"
export GRE_INTERNET_TARGET_IP="1.1.1.1"
export GRE_INTERNET_TARGET_TCP_PORT="53"
export GRE_UNDERLAY_REMOTE_IP="<gre-peer-underlay-ip>"

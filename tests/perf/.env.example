# CubeSandbox perf — 环境变量示例
# 复制为 tests/.env 后编辑。CLI 与环境变量优先于 .env。
#
# 首次运行时若没有 .env 会自动生成一份（全部注释占位）；
# 跑完后本次实际用到的值二次写回，下次直接 python3 -m perf 复用。

# ===========================================================================
# 目标环境与鉴权
# ===========================================================================
CUBE_API_URL=http://127.0.0.1:3000
CUBE_API_KEY=
CUBE_TEMPLATE_ID=
CUBE_PROXY_NODE_IP=
CUBE_PROXY_PORT_HTTP=80
CUBE_SANDBOX_DOMAIN=cube.app

# ===========================================================================
# 外部压测脚本（逗号分隔 .py 路径，约定 -c -n --rounds --no-header）
# ===========================================================================
# 取消注释并修改为你脚本的实际路径；6 个内置场景示例：
# CUBE_EXTERNAL_SCRIPTS=../sdk/python/examples/snapshot-rollback-clone/bench_clone_concurrency.py,../sdk/python/examples/snapshot-rollback-clone/bench_create_concurrency.py,../sdk/python/examples/snapshot-rollback-clone/bench_snapshot_concurrency.py,../sdk/python/examples/snapshot-rollback-clone/bench_rollback_concurrency.py,../sdk/python/examples/snapshot-rollback-clone/bench_pause_resume_concurrency.py,../sdk/python/examples/snapshot-rollback-clone/bench_snapshot_dirty.py

# ===========================================================================
# 场景开关
# ===========================================================================
# 启用 ivshmem：设为 1（需节点 host + ivshmem 模板）
# CUBE_RUN_IVSHMEM=1
# 启用 Volume：设为 1
# CUBE_RUN_VOLUME=1
# 跳过密度测试：设为 1
# CUBE_SKIP_DENSITY=1
# 跳过脏页测试：设为 1
# CUBE_SKIP_SNAPSHOT_DIRTY=1
# ivshmem 专用模板（留空回落 CUBE_TEMPLATE_ID）
# CUBE_IVSHMEM_TEMPLATE_ID=
# ivshmem mmap 迭代次数
CUBE_IVSHMEM_ITERATIONS=10000

# ===========================================================================
# 运行参数
# ===========================================================================
CUBE_PERF_ROUNDS=3
CUBE_PERF_CONCURRENCY=1,5,10
CUBE_CREATE_CONCURRENCY=1,10,20,50
CUBE_PERF_WARMUP=1
CUBE_PERF_SETTLE=0
CUBE_DENSITY_COUNT=100
CUBE_PERF_CLEANUP=1

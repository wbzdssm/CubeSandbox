# CubeSandbox control-plane endpoint used by the adapter, preflight,
# diagnostics, and cleanup.
CUBE_API_URL=http://127.0.0.1:3000
# READY template used when creating test sandboxes.
CUBE_TEMPLATE_ID=tpl-xxxxxxxxxxxxxxxxxxxxxxxx
# Optional CubeSandbox API key. It is not used as E2B_API_KEY.
# CUBE_API_KEY=your-cube-api-key

# CubeProxy routing for sandbox data-plane traffic. Set CUBE_PROXY_NODE_IP when
# the test runner cannot resolve the wildcard sandbox hostname.
# CUBE_PROXY_NODE_IP=10.0.1.2
# HTTP port exposed by CubeProxy.
CUBE_PROXY_PORT_HTTP=80
# Wildcard domain used to construct sandbox hostnames.
CUBE_SANDBOX_DOMAIN=cube.app

# Operation timeouts in seconds. DEFAULT covers connect/resume and cleanup;
# API covers control-plane HTTP requests; CREATE, COMMAND, and RUN_CODE cover
# their respective operations.

<<<<<<< HEAD
# Public TCP endpoints used by network policy tests. Configure targets that are
# reachable and stable from the test environment.
SDK_E2E_TCP_TARGET_IP=8.8.8.8
SDK_E2E_TCP_TARGET_PORT=53
SDK_E2E_ALTERNATE_TCP_TARGET_IP=1.1.1.1
# Exposed sandbox HTTP endpoint used by restrict-public-access inbound tests.
# The default targets envd health on the standard exposed envd port. Override
# these values when the template exposes a different HTTP service. envd
# /health normally returns HTTP 204 with an empty body.
# The default public URL uses HTTP, so traffic access tokens are sent in
# cleartext. Use an HTTPS endpoint for cross-network or multi-tenant CI.
SDK_E2E_PUBLIC_ACCESS_PORT=49983
SDK_E2E_PUBLIC_ACCESS_PATH=/health
SDK_E2E_PUBLIC_ACCESS_EXPECTED_STATUS=204
SDK_E2E_PUBLIC_ACCESS_EXPECTED_BODY=

# When E2B tests target a local/self-hosted CubeSandbox deployment, sandbox
# command/file/run_code traffic may use HTTPS with a private CA. Point
# SSL_CERT_FILE to that CA bundle; do not disable TLS verification.
# SSL_CERT_FILE=/root/.local/share/mkcert/rootCA.pem

# Keep the main sandbox only when setup/call fails. Passed, skipped,
# teardown-only failures, and peer/control sandboxes are still cleaned up.
# Set back to false for normal runs.
SDK_E2E_KEEP_SANDBOX_ON_FAILURE=false
# Print every SDK adapter operation. Failed tests include a recent trace even
# when this is false.
# SDK_E2E_TRACE=true
# Skip requires_internet tests when the runner has no stable public egress.
# SDK_E2E_SKIP_INTERNET_TESTS=false
# Directory for JSONL events.jsonl and related reports.
=======
# Public TCP endpoints used by network policy tests.
SDK_E2E_TCP_TARGET_IP=8.8.8.8
SDK_E2E_TCP_TARGET_PORT=53
SDK_E2E_ALTERNATE_TCP_TARGET_IP=1.1.1.1


[Unit]
Description=Cube Sandbox Redis container
After=docker.service network-online.target
Requires=docker.service
Wants=network-online.target
ConditionPathExists=/usr/local/services/cubetoolbox/.one-click.env
PartOf=cube-sandbox-control.target

[Service]
Type=simple
User=root
WorkingDirectory=/usr/local/services/cubetoolbox
EnvironmentFile=-/usr/local/services/cubetoolbox/.one-click.env
ExecStartPre=/usr/bin/bash /usr/local/services/cubetoolbox/scripts/systemd/redis-prepare.sh
ExecStart=/usr/bin/bash /usr/local/services/cubetoolbox/scripts/systemd/redis-start.sh
ExecStartPost=/usr/bin/bash /usr/local/services/cubetoolbox/scripts/systemd/redis-postcheck.sh
ExecStop=/usr/bin/bash /usr/local/services/cubetoolbox/scripts/systemd/redis-stop.sh
Restart=on-failure
RestartSec=2s
# Override short distro defaults explicitly.
TimeoutStartSec=60s
TimeoutStopSec=30s

[Install]
WantedBy=cube-sandbox-control.target

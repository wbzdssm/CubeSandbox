# Terraform working files
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
crash.log

# Runtime artifacts generated by create.sh / destroy.sh
.kube/
.ssh/
# Saved deployment selections (contains credentials/passwords; never commit)
.env
.env.*
# terraform CLI auto-installed by create.sh into a local bin dir
.bin/
# TLS material generated for the cube-proxy CLB (never commit keys)
cubeproxy-certs/
# Defense in depth: never commit private keys, credentials or tfvars
*.pem
*.key
credentials*
*.tfvars
*.tfvars.json
# Derived from the canonical deploy/one-click/webui/nginx.conf at build/run time
webui-nginx.conf
